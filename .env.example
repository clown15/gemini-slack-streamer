# Slack-Gemini Bridge Bot Environment Variables Example
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.

# [Slack API Tokens]
# Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token (xapp-...) - Connections:Write 권한 필요
SLACK_APP_TOKEN=xapp-your-app-token-here

# [Channel Settings]
# 봇이 작동할 전용 채널 ID (예: C0123456789)
ALLOWED_CHANNEL_ID=C0000000000

# [Optional Settings]
# 필요 시 추가적인 환경 변수를 설정하세요.
WORKSPACE_PATH=/app/workspace

# [User Permission Settings]
# 호스트 사용자와의 권한 일치를 위한 ID 설정 (Linux 권장)
# 터미널에서 `id -u`, `id -g` 명령어로 확인 가능합니다.
USER_ID=1000
GROUP_ID=1000
USER_NAME=ubuntu
